# ---------- Firebase (client SDK) ----------
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ---------- Firebase Admin SDK (server-side only, required for auth + Firestore) ----------
# Paste the FULL contents of your serviceAccountKey.json as a single-line JSON string.
# Get it from Firebase Console → Project Settings → Service accounts → Generate new private key.
# For local dev the file itself is used; for Vercel set this environment variable.
FIREBASE_SERVICE_ACCOUNT_JSON=

# ---------- AI providers (server-side only, never exposed to client) ----------
# Leave all blank to use built-in mock AI responses.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# Which provider to use: "mock" (default) | "anthropic" | "openai" | "gemini"
AI_PROVIDER=mock

# ---------- Social platform APIs (read-only live metrics) ----------
# Leave blank to stay in demo mode. See SOCIAL_SETUP.md for step-by-step setup.

# YouTube: a FREE Data API v3 key from Google Cloud. Shows real subscribers,
# views and recent uploads for @sriadarshavanihighschooldu7480. No OAuth needed.
YOUTUBE_API_KEY=

# Instagram (Graph API): needs a Professional account + linked Facebook Page +
# Meta app + long-lived token. The two IG accounts each need their Business id.
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_IG_USER_ID_NARAYANA=
INSTAGRAM_IG_USER_ID_ADARSHAVANI=

# Facebook Pages API (optional, for Page metrics later).
FACEBOOK_PAGE_TOKEN=

# ---------- Auto-post admin PIN ----------
# Required to authorise posting APPROVED content. Change this and do NOT commit the real value.
# NOTE: a NEXT_PUBLIC_ var is visible in the browser — for real security, verify the PIN
# in a server route / Cloud Function and store only a hash.
NEXT_PUBLIC_AUTOPOST_PIN=2580
