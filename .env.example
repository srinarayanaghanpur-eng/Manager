# ---------- Firebase (client SDK) ----------
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ---------- AI providers (server-side only, never exposed to client) ----------
# Leave all blank to use built-in mock AI responses.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# Which provider to use: "mock" (default) | "anthropic" | "openai" | "gemini"
AI_PROVIDER=mock

# ---------- Social platform APIs (for real metrics + manual/auto publishing) ----------
# Leave blank to stay in read-only mock mode. Auto-post stays disabled until these are set.
INSTAGRAM_ACCESS_TOKEN=
FACEBOOK_PAGE_TOKEN=
YOUTUBE_API_KEY=

# ---------- Auto-post admin PIN ----------
# Required to authorise posting APPROVED content. Change this and do NOT commit the real value.
# NOTE: a NEXT_PUBLIC_ var is visible in the browser — for real security, verify the PIN
# in a server route / Cloud Function and store only a hash.
NEXT_PUBLIC_AUTOPOST_PIN=2580
